# ─────────────────────────────────────────────────────────────────────────────
# REQUIRED
# ─────────────────────────────────────────────────────────────────────────────

OPENAI_API_KEY=your_openai_api_key_here


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Web Search  (Serper.dev)
#
# Enables the bot to answer: hotel phone numbers, Google Maps links,
# distances from airports, directions, nearby makeup artists, pharmacies, etc.
#
# Free tier: 2,500 searches/month — no credit card required.
# Sign up at https://serper.dev, copy your API key below.
#
# If left blank, the bot tells guests to check online for such queries.
# ─────────────────────────────────────────────────────────────────────────────

SERPER_API_KEY=your_serper_key_here


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Admin Number
#
# Your WhatsApp number in international format — digits only, no '+' or spaces.
# Example: if your number is +91 98765 43210, set:  ADMIN_NUMBER=919876543210
#
# When set, you can message the bot directly with admin commands:
#   /stats              — see usage stats (unique guests, total messages)
#   /broadcast <msg>    — send a message to all guests who've ever messaged the bot
#   /reset <phone>      — clear a guest's conversation history
# ─────────────────────────────────────────────────────────────────────────────

ADMIN_NUMBER=


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Persistent Store Path
#
# Path to the JSON file where conversation history and the user registry are
# saved so they survive bot restarts.
#
# LOCAL (Mac Mini): leave blank — defaults to ./store.json in the project folder.
#
# RAILWAY: set this to a path inside your mounted persistent volume, e.g.:
#   STORE_PATH=/data/store.json
# ─────────────────────────────────────────────────────────────────────────────

STORE_PATH=


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: WhatsApp Session Path  (Railway only)
#
# Path where the WhatsApp session is stored. Defaults to ./.wwebjs_auth
# On Railway, point this to your persistent volume:
#   WWEBJS_AUTH_PATH=/data/.wwebjs_auth
# ─────────────────────────────────────────────────────────────────────────────

WWEBJS_AUTH_PATH=


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: Chrome Executable Path  (Railway / Linux only)
#
# If nixpacks installs system Chromium and you want to use it instead of the
# Puppeteer-bundled Chromium, set this to the binary path.
# Example: CHROME_PATH=/usr/bin/chromium
#
# Leave blank to use the Puppeteer-bundled Chromium (works locally and on Railway
# if the system libraries from nixpacks.toml are present).
# ─────────────────────────────────────────────────────────────────────────────

CHROME_PATH=


# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL: TTS Voice
#
# Which OpenAI TTS voice to use for voice note replies.
# Options: alloy, echo, fable, nova, onyx, shimmer
# Default: nova  (warm and clear — works well for both English and Hindi)
# ─────────────────────────────────────────────────────────────────────────────

TTS_VOICE=nova
